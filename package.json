{
  "name": "ai-tutor-platform",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "lint": "pnpm -r --if-present lint && pnpm verify:design",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "build": "pnpm -r --if-present build",
    "verify:design": "bash scripts/verify_design_conformance.sh",
    "verify:migrations": "bash scripts/verify_migrations.sh",
    "verify:deploy": "bash scripts/verify_deploy_builds.sh",
    "checklist:env": "bash scripts/generate_launch_checklist.sh",
    "posthog:dashboard:spec": "bash scripts/posthog/dashboard_spec_cli.sh",
    "posthog:weekly:report": "bash scripts/posthog/weekly_optimization_report_cli.sh",
    "verify:all": "pnpm checklist:env && pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm test:e2e && pnpm build && pnpm verify:migrations && pnpm verify:deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.23.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
